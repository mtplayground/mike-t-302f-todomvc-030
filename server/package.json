{
  "name": "@todomvc-030/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "npm run prisma:generate && tsc -p tsconfig.json",
    "dev": "tsx watch src/server.ts",
    "prisma:generate": "prisma generate --config prisma.config.ts",
    "prisma:migrate": "prisma migrate deploy --config prisma.config.ts",
    "prisma:validate": "prisma validate --config prisma.config.ts",
    "start": "node dist/server.js",
    "typecheck": "npm run prisma:generate && tsc -p tsconfig.json --noEmit",
    "test": "echo \"No server tests configured yet\""
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "express": "^5.2.1",
    "pg": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/pg": "^8.20.0",
    "prisma": "^7.8.0",
    "tsx": "^4.22.4"
  }
}
